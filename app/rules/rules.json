{
  "categories": [
    {
      "id": "missing_param",
      "name": "Missing parameter",
      "description": "Required configuration parameter is missing",
      "severity": "high",
      "matching_rules": [
        {"type": "missing_field", "field": "input.path"},
        {"type": "substring", "phrases": ["KeyError", "missing required", "not found in config"]}
      ],
      "probable_root_causes": ["User omitted required config parameter","Template generation error"],
      "next_steps": ["Verify config contains 'input.path'","Check deployment template for missing keys"],
      "example_phrases": ["KeyError: 'input'", "missing required parameter"]
    },
    {
      "id": "invalid_value",
      "name": "Invalid parameter value",
      "description": "A parameter value is outside allowed choices",
      "severity": "medium",
      "matching_rules": [
        {"type": "invalid_value", "field": "runtime.mode", "allowed_values": ["batch","stream"]},
        {"type": "substring", "phrases": ["invalid value", "unsupported value"]}
      ],
      "probable_root_causes": ["Typo in config","Deprecated option used"],
      "next_steps": ["Validate config schema","Refer to docs for allowed values"]
    },
    {
      "id": "missing_file",
      "name": "Bad input path / missing file",
      "description": "A referenced input file or path was not found",
      "severity": "high",
      "matching_rules": [
        {"type": "path_missing", "field": "input.path"},
        {"type": "substring", "phrases": ["No such file or directory", "FileNotFoundError"]}
      ],
      "probable_root_causes": ["Missing input files","Wrong path in config"],
      "next_steps": ["Confirm path exists","Upload missing input files or correct path"]
    },
    {
      "id": "schema_mismatch",
      "name": "Schema mismatch",
      "description": "Input data doesn't match expected schema",
      "severity": "medium",
      "matching_rules": [
        {"type": "substring", "phrases": ["schema mismatch", "SchemaValidationError", "unexpected field"]},
        {"type": "regex", "patterns": ["column .* not found", "missing column"]}
      ],
      "probable_root_causes": ["Downstream data format change","Incorrect schema declared"],
      "next_steps": ["Inspect input sample","Update schema or transform input"]
    },
    {
      "id": "permission",
      "name": "Permission or access issue",
      "description": "Access denied to resource or file",
      "severity": "high",
      "matching_rules": [
        {"type": "substring", "phrases": ["Permission denied", "AccessDenied", "403 Forbidden"]}
      ],
      "probable_root_causes": ["Credentials missing or expired","Network policy blocks access"],
      "next_steps": ["Check service account permissions","Inspect firewall/policies"]
    },
    {
      "id": "missing_dependency",
      "name": "Missing dependency or package",
      "description": "Required package or binary is not installed",
      "severity": "medium",
      "matching_rules": [
        {"type": "substring", "phrases": ["ModuleNotFoundError", "No module named", "command not found"]}
      ],
      "probable_root_causes": ["Deployment missing dependency","Virtualenv not activated"],
      "next_steps": ["Install missing package","Check environment activation"]
    },
    {
      "id": "upstream_failure",
      "name": "Upstream service failure",
      "description": "A downstream or upstream service returned errors",
      "severity": "high",
      "matching_rules": [
        {"type": "substring", "phrases": ["503 Service Unavailable", "502 Bad Gateway", "timed out connecting"]}
      ],
      "probable_root_causes": ["Service outage","Network partition"],
      "next_steps": ["Check service status","Retry with backoff"]
    },
    {
      "id": "timeout",
      "name": "Timeout / resource issue",
      "description": "Operation timed out or ran out of resources",
      "severity": "high",
      "matching_rules": [
        {"type": "substring", "phrases": ["timed out", "TimeoutError", "out of memory", "OOM"]}
      ],
      "probable_root_causes": ["Insufficient resources","Blocking operation"],
      "next_steps": ["Increase timeout or resources","Profile job for hot spots"]
    }
  ]
}